# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Meta/WhatsApp Configuration
NEXT_PUBLIC_META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token
META_WEBHOOK_SECRET=your_webhook_secret
NEXT_PUBLIC_WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
NEXT_PUBLIC_WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token

# Security Configuration
# Set to 'true' to enable Meta review mode on staging (bypasses MFA for Meta inspector)
NEXT_PUBLIC_META_REVIEW_MODE=false

# Node Environment
NODE_ENV=production
